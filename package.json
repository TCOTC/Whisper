{
  "name": "whisper-theme-builder",
  "version": "2.0.0",
  "private": true,
  "description": "Whisper Theme Building Tool",
  "main": "theme.js",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "cd builder && vite build --watch",
    "build": "cd builder && vite build && node zip-package.mjs",
    "lint": "pnpm exec eslint --config builder/eslint.config.mjs",
    "push": "git push origin HEAD --tags"
  },
  "keywords": [
    "siyuan",
    "theme"
  ],
  "author": "Jeffrey Chen",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.0.1",
    "bestzip": "^3.0.1",
    "eslint": "^9.39.2",
    "globals": "^16.5.0",
    "sass": "^1.96.0",
    "siyuan": "1.1.5",
    "terser": "^5.44.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0",
    "vite": "^8.1.3"
  }
}